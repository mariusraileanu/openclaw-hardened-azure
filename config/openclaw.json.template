{
  "models": {
    "mode": "merge",
    "providers": {
      "compass": {
        "baseUrl": "${COMPASS_BASE_URL}",
        "apiKey": "${COMPASS_API_KEY}",
        "api": "openai-completions",
        "models": [
          {
            "id": "gpt-5.1",
            "name": "GPT 5.1",
            "contextWindow": 200000,
            "maxTokens": 8192
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "compass/gpt-5.1"
      },
      "workspace": "${OPENCLAW_STATE_DIR}/workspace"
    }
  },
  "tools": {
    "exec": {
      "host": "gateway"
    },
    "web": {
      "search": {
        "provider": "tavily"
      }
    }
  },
  "gateway": {
    "auth": {
      "mode": "none"
    }
  },
  "plugins": {
    "entries": {
      "tavily": {
        "enabled": true,
        "config": {
          "webSearch": {
            "baseUrl": "https://api.tavily.com"
          }
        }
      }
    }
  },
  "channels": {
    "signal": {
      "enabled": false,
      "account": "${SIGNAL_BOT_NUMBER}",
      "httpUrl": "${SIGNAL_HTTP_URL}",
      "autoStart": false,
      "dmPolicy": "allowlist",
      "allowFrom": ["${SIGNAL_USER_PHONE}"]
    },
    "msteams": {
      "enabled": true,
      "appId": "${MSTEAMS_APP_ID}",
      "appPassword": "${MSTEAMS_APP_PASSWORD}",
      "tenantId": "${MSTEAMS_TENANT_ID}",
      "webhook": {
        "port": 3978,
        "path": "/api/messages"
      },
      "requireMention": true,
      "replyStyle": "thread"
    }
  }
}
