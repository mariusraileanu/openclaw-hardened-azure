# Shared dev environment config template
AZURE_ENVIRONMENT=dev
AZURE_LOCATION=eastus
AZURE_OWNER_SLUG=platform
IMAGE_TAG=latest
COMPASS_BASE_URL=https://api.core42.ai/v1

# Shared resource-name overrides (optional)
AZURE_RESOURCE_GROUP=rg-openclaw-dev
AZURE_CONTAINERAPPS_ENV=cae-openclaw-dev
AZURE_ACR_NAME=openclawdevacr
AZURE_KEY_VAULT_NAME=kvopenclawdev
NFS_SA_NAME=nfsopenclawdev
CAE_NFS_STORAGE_NAME=openclaw-nfs-dev

# Shared secrets (required for deploy)
COMPASS_API_KEY=replace-me

# Optional shared secrets
TAVILY_API_KEY=

# Signal shared settings
SIGNAL_BOT_NUMBER=
SIGNAL_PROXY_AUTH_TOKEN=
SIGNAL_CLI_URL=

# Optional Teams shared settings
MSTEAMS_RELAY_ENABLED=false
MSTEAMS_TENANT_ID=
MSTEAMS_APP_ID=
MSTEAMS_APP_SECRET_VALUE=
MSTEAMS_USER_SLUG_MAP={}
