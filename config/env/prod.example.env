# Shared prod environment config template
AZURE_ENVIRONMENT=prod
AZURE_LOCATION=uaenorth
AZURE_OWNER_SLUG=platform
IMAGE_TAG=latest
COMPASS_BASE_URL=https://api.core42.ai/v1

# Shared resource names (usually required in prod)
AZURE_RESOURCE_GROUP=rg-openclaw-prod
AZURE_CONTAINERAPPS_ENV=cae-openclaw-prod
AZURE_ACR_NAME=openclawprodacr
AZURE_KEY_VAULT_NAME=kvopenclawprod
NFS_SA_NAME=nfsopenclawprod
CAE_NFS_STORAGE_NAME=openclaw-nfs-prod

# Terraform state backend
TF_STATE_RG=rg-openclaw-tfstate-prod
TF_STATE_SA=tfopenclawstateprod

# Shared secrets (required)
COMPASS_API_KEY=replace-me

# Optional shared secrets
TAVILY_API_KEY=

# Signal shared settings
SIGNAL_BOT_NUMBER=
SIGNAL_PROXY_AUTH_TOKEN=
SIGNAL_CLI_URL=

# Optional Teams shared settings
MSTEAMS_RELAY_ENABLED=false
MSTEAMS_TENANT_ID=
MSTEAMS_APP_ID=
MSTEAMS_APP_SECRET_VALUE=
MSTEAMS_USER_SLUG_MAP={}
