# Terraform
**/.terraform/
# State is stored in Azure Blob (remote backend) — these patterns are a safety
# net to prevent accidental commits of local state files.
*.tfstate
*.tfstate.*
*.tfplan
*.tfvars
!*.tfvars.example

# Azure exports / test artifacts
test-mcp.yaml

# Secrets — never commit
*.pem
*.key
.env
.env.*
!.env.example
!.env.azure.example
secrets.auto.tfvars

# Compiled binaries
signal-proxy/signal-proxy

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo
*~
