# Terraform
**/.terraform/
# State is stored in Azure Blob (remote backend) — these patterns are a safety
# net to prevent accidental commits of local state files.
*.tfstate
*.tfstate.*
*.tfplan
tfplan-*
*.tfvars
!*.tfvars.example
# Local backend override used when deploying to prod (local TF state)
backend_override.tf

# Node.js
node_modules/

# Python bytecode
__pycache__/
*.pyc

# Build output / test artifacts
test-mcp.yaml
channels/teams-app/dist/
channels/teams-relay/dist/

# Azure Functions local settings (may contain connection strings)
local.settings.json

# Secrets — never commit
*.pem
*.key
.env
.env.*
config/**/*.env
!config/**/*.example.env
!config/.gitkeep
secrets.auto.tfvars

# Compiled binaries
channels/signal-proxy/signal-proxy

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo
*~

# Board domain data (member evidence, KB, meetings, board definitions)
config/boards/

# Tool config
.opencode/
