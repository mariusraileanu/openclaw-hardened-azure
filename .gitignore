# Terraform
**/.terraform/
# State is stored in Azure Blob (remote backend) — these patterns are a safety
# net to prevent accidental commits of local state files.
*.tfstate
*.tfstate.*
*.tfplan
*.tfvars
!*.tfvars.example

# Node.js
node_modules/

# Python bytecode
__pycache__/
*.pyc

# Build output / test artifacts
test-mcp.yaml
teams-app/dist/
teams-relay/dist/

# Azure Functions local settings (may contain connection strings)
local.settings.json

# Secrets — never commit
*.pem
*.key
.env
.env.*
config/**/*.env
!config/**/*.example.env
!config/.gitkeep
secrets.auto.tfvars

# Compiled binaries
signal-proxy/signal-proxy

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo
*~
