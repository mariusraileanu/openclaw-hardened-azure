# ===========================================================================
# OpenClaw Azure Platform — Per-User Configuration
# ===========================================================================
# Copy this file to .env.user.<slug> (e.g. .env.user.alice, .env.user.bob).
# The Makefile loads .env.user.$(U) automatically when you pass U=<slug>.
#
# Usage:
#   make add-user U=alice ENV=prod    # loads .env.azure.prod + .env.user.alice
#   make add-user U=bob   ENV=prod    # loads .env.azure.prod + .env.user.bob
#
# Values here override the shared defaults from .env.azure.<env>.
# ===========================================================================

# ---------------------------------------------------------------------------
# Signal Messaging (optional — leave empty or omit to skip Signal for user)
# ---------------------------------------------------------------------------
SIGNAL_USER_PHONE=+15551234567

# ---------------------------------------------------------------------------
# API Keys (optional overrides — defaults come from .env.azure.<env>)
# Uncomment to use a different key for this specific user.
# ---------------------------------------------------------------------------
# COMPASS_API_KEY=sk-compass-xxx
# OPENCLAW_GATEWAY_AUTH_TOKEN=gw-token-xxx
# TAVILY_API_KEY=tvly-xxx
