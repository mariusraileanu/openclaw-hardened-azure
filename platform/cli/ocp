def _print_error(code: str, message: str) -> None:
    print(f"ERROR[{code}]: {message}", file=sys.stderr)


def _run_op(func, *args) -> int:
    try:
        return func(*args)
    except FileNotFoundError as exc:
        _print_error("CONFIG_MISSING", str(exc))
        return 2
    except RuntimeError as exc:
        message = str(exc)
        lowered = message.lower()
        code = "RUNTIME"
        if "azure cli session is not active" in lowered or "refresh azure auth" in lowered:
            code = "AZ_AUTH"
        elif "missing required shared config keys" in lowered:
            code = "CONFIG_REQUIRED"
        elif "naming contract" in lowered:
            code = "NAMING"
        _print_error(code, message)
        return 1
    except Exception as exc:
        _print_error("UNEXPECTED", str(exc))
        return 99


def run(cmd: list[str]) -> int:
    result = subprocess.run(cmd, cwd=REPO_ROOT)
    return result.returncode


def run_make(target: str, env_name: str, user: str | None = None) -> int:
    command = ["make", target, f"ENV={env_name}"]
    if user:
        command.append(f"U={user}")
    return run(command)


def cmd_config_bootstrap(args: argparse.Namespace) -> int:
    return bootstrap_config(REPO_ROOT, args.env, args.user)


def cmd_config_validate(args: argparse.Namespace) -> int:
    command = ["./platform/scripts/validate_config.py", "--env", args.env]
    if args.user:
        command.extend(["--user", args.user])
    rc = run(command)
    if rc != 0:
        return rc
    feature_command = ["./platform/scripts/validate_features.py", "--env", args.env]
    if args.user:
        feature_command.extend(["--user", args.user])
    rc = run(feature_command)
    if rc != 0:
        return rc
    return run(["./platform/scripts/validate_member_evidence.py"])


