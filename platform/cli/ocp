def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(prog="ocp", description="OpenClaw platform CLI")
    subparsers = parser.add_subparsers(dest="command", required=True)

    config_parser = subparsers.add_parser("config", help="Config operations")
    config_sub = config_parser.add_subparsers(dest="config_cmd", required=True)

    config_bootstrap = config_sub.add_parser(
        "bootstrap", help="Create missing env files from templates"
    )
    config_bootstrap.add_argument("--env", default="dev")
    config_bootstrap.add_argument("--user")
    config_bootstrap.set_defaults(func=cmd_config_bootstrap)

    config_validate = config_sub.add_parser(
        "validate", help="Validate env files against schema"
    )
    config_validate.add_argument("--env", default="dev")
    config_validate.add_argument("--user")
    config_validate.set_defaults(func=cmd_config_validate)

    deploy_parser = subparsers.add_parser("deploy", help="Deploy operations")
    deploy_sub = deploy_parser.add_subparsers(dest="deploy_cmd", required=True)

    deploy_shared = deploy_sub.add_parser("shared", help="Deploy shared infrastructure")
    deploy_shared.add_argument("--env", default="dev")
    deploy_shared.add_argument("--plan", action="store_true")
    deploy_shared.add_argument("--destroy", action="store_true")
    deploy_shared.set_defaults(func=cmd_deploy_shared)

    deploy_user = deploy_sub.add_parser("user", help="Deploy user application")
    deploy_user.add_argument("--env", default="dev")
    deploy_user.add_argument("--user", required=True)
    deploy_user.add_argument("--plan", action="store_true")
    deploy_user.set_defaults(func=cmd_deploy_user)

    user_parser = subparsers.add_parser("user", help="User lifecycle operations")
    user_sub = user_parser.add_subparsers(dest="user_cmd", required=True)

    user_remove = user_sub.add_parser("remove", help="Remove user application")
    user_remove.add_argument("--env", default="dev")
    user_remove.add_argument("--user", required=True)
    user_remove.set_defaults(func=cmd_user_remove)

    user_import = user_sub.add_parser(
        "import", help="Import existing Azure resource into user Terraform state"
    )
    user_import.add_argument("--env", default="dev")
    user_import.add_argument("--user", required=True)
    user_import.add_argument("--resource", required=True)
    user_import.add_argument("--azure-id", required=True)
    user_import.set_defaults(func=cmd_user_import)

    status_parser = subparsers.add_parser("status", help="Show app status")
    status_parser.add_argument("--env", default="dev")
    status_parser.add_argument("--user")
    status_parser.set_defaults(func=cmd_status)

    logs_parser = subparsers.add_parser("logs", help="Tail user logs")
    logs_parser.add_argument("--env", default="dev")
    logs_parser.add_argument("--user", required=True)
    logs_parser.set_defaults(func=cmd_logs)

    usage_parser = subparsers.add_parser(
        "usage", help="Show request-level usage by user"
    )
    usage_parser.add_argument("--env", default="dev")
    usage_parser.add_argument("--user")
    usage_parser.add_argument(
        "--hours", type=int, default=24, help="Lookback window in hours"
    )
    usage_parser.add_argument(
        "--workspace-id",
        help="Log Analytics workspace customerId (auto-resolved by default)",
    )
    usage_parser.add_argument(
        "--source",
        choices=["log-analytics", "sessions"],
        default="log-analytics",
        help="Data source: relay logs (log-analytics) or session history files (sessions)",
    )
    usage_parser.add_argument(
        "--probe-user",
        help="When source=sessions, run extraction from this user's container app",
    )
    usage_parser.set_defaults(func=cmd_usage)

    reset_parser = subparsers.add_parser("reset", help="Platform reset operations")
    reset_parser.add_argument("--env", default="dev")
    reset_parser.add_argument("--force", action="store_true")
    group = reset_parser.add_mutually_exclusive_group()
    group.add_argument("--nuke-only", action="store_true")
    group.add_argument("--rebuild-only", action="store_true")
    reset_parser.set_defaults(func=cmd_reset)

    signal_parser = subparsers.add_parser("signal", help="Signal stack operations")
    signal_sub = signal_parser.add_subparsers(dest="signal_cmd", required=True)

    signal_build_cmd = signal_sub.add_parser("build", help="Build signal-proxy image")
    signal_build_cmd.add_argument("--env", default="dev")
    signal_build_cmd.set_defaults(func=cmd_signal_build)

    signal_deploy_cmd = signal_sub.add_parser(
        "deploy", help="Deploy signal stack (shared infra + proxy)"
    )
    signal_deploy_cmd.add_argument("--env", default="dev")
    signal_deploy_cmd.add_argument("--plan", action="store_true")
    signal_deploy_cmd.set_defaults(func=cmd_signal_deploy)

    signal_status_cmd = signal_sub.add_parser("status", help="Show signal stack status")
    signal_status_cmd.add_argument("--env", default="dev")
    signal_status_cmd.set_defaults(func=cmd_signal_status)

    signal_logs_cli_cmd = signal_sub.add_parser("logs-cli", help="Tail signal-cli logs")
    signal_logs_cli_cmd.add_argument("--env", default="dev")
    signal_logs_cli_cmd.set_defaults(func=cmd_signal_logs_cli)

    signal_logs_proxy_cmd = signal_sub.add_parser(
        "logs-proxy", help="Tail signal-proxy logs"
    )
    signal_logs_proxy_cmd.add_argument("--env", default="dev")
    signal_logs_proxy_cmd.set_defaults(func=cmd_signal_logs_proxy)

    signal_register_cmd = signal_sub.add_parser(
        "register", help="Open shell in signal-cli for phone registration"
    )
    signal_register_cmd.add_argument("--env", default="dev")
    signal_register_cmd.set_defaults(func=cmd_signal_register)

    signal_update_cmd = signal_sub.add_parser(
        "update-phones", help="Sync SIGNAL_KNOWN_PHONES on signal-proxy"
    )
    signal_update_cmd.add_argument("--env", default="dev")
    signal_update_cmd.set_defaults(func=cmd_signal_update_phones)

    teams_parser = subparsers.add_parser("teams", help="Teams relay operations")
    teams_sub = teams_parser.add_subparsers(dest="teams_cmd", required=True)

    teams_relay_build_cmd = teams_sub.add_parser(
        "relay-build", help="Build the Teams relay Function App"
    )
    teams_relay_build_cmd.add_argument("--env", default="dev")
    teams_relay_build_cmd.set_defaults(func=cmd_teams_relay_build)

    teams_relay_deploy_cmd = teams_sub.add_parser(
        "relay-deploy", help="Deploy Teams relay infra and build artifacts"
    )
    teams_relay_deploy_cmd.add_argument("--env", default="dev")
    teams_relay_deploy_cmd.set_defaults(func=cmd_teams_relay_deploy)

    teams_manifest_cmd = teams_sub.add_parser(
        "manifest", help="Render Teams manifest for one environment"
    )
    teams_manifest_cmd.add_argument("--env", default="dev")
    teams_manifest_cmd.set_defaults(func=cmd_teams_manifest)

    teams_manifest_all_cmd = teams_sub.add_parser(
        "manifest-all", help="Render Teams manifests for dev/stage/prod"
    )
    teams_manifest_all_cmd.set_defaults(func=cmd_teams_manifest_all)

    teams_validate_cmd = teams_sub.add_parser(
        "validate", help="Validate Teams manifest for one environment"
    )
    teams_validate_cmd.add_argument("--env", default="dev")
    teams_validate_cmd.set_defaults(func=cmd_teams_validate)

    teams_package_cmd = teams_sub.add_parser(
        "package", help="Build Teams package zip for one environment"
    )
    teams_package_cmd.add_argument("--env", default="dev")
    teams_package_cmd.set_defaults(func=cmd_teams_package)

    teams_release_check_cmd = teams_sub.add_parser(
        "release-check", help="Run full Teams local release gate"
    )
    teams_release_check_cmd.set_defaults(func=cmd_teams_release_check)

    teams_routing_parser = teams_sub.add_parser(
        "routing", help="Manage Teams relay routing records"
    )
    teams_routing_sub = teams_routing_parser.add_subparsers(
        dest="teams_routing_cmd", required=True
    )

    teams_routing_upsert_cmd = teams_routing_sub.add_parser(
        "upsert", help="Create or update a routing record"
    )
    teams_routing_upsert_cmd.add_argument("--env", default="dev")
    teams_routing_upsert_cmd.add_argument("--aad-object-id", required=True)
    teams_routing_upsert_cmd.add_argument("--user-slug", required=True)
    teams_routing_upsert_cmd.add_argument("--upstream-url", required=True)
    teams_routing_upsert_cmd.add_argument(
        "--status", default="active", choices=["active", "provisioning", "disabled"]
    )
    teams_routing_upsert_cmd.set_defaults(func=cmd_teams_routing_upsert)

    teams_routing_get_cmd = teams_routing_sub.add_parser(
        "get", help="Get one routing record"
    )
    teams_routing_get_cmd.add_argument("--env", default="dev")
    teams_routing_get_cmd.add_argument("--aad-object-id", required=True)
    teams_routing_get_cmd.set_defaults(func=cmd_teams_routing_get)

    teams_routing_disable_cmd = teams_routing_sub.add_parser(
        "disable", help="Set status=disabled for a routing record"
    )
    teams_routing_disable_cmd.add_argument("--env", default="dev")
    teams_routing_disable_cmd.add_argument("--aad-object-id", required=True)
    teams_routing_disable_cmd.set_defaults(func=cmd_teams_routing_disable)

    doctor_parser = subparsers.add_parser("doctor", help="Run local preflight diagnostics")
    doctor_parser.add_argument("--env", default="dev")
    doctor_parser.add_argument("--user")
    doctor_parser.set_defaults(func=cmd_doctor)

    graph_parser = subparsers.add_parser("graph", help="Graph gateway operations")
    graph_sub = graph_parser.add_subparsers(dest="graph_cmd", required=True)

    graph_auth_parser = graph_sub.add_parser(
        "auth-check", help="Check graph gateway auth identity by user"
    )
    graph_auth_parser.add_argument("--env", default="dev")
    graph_auth_parser.add_argument("--user", action="append", required=True)
    graph_auth_parser.set_defaults(func=cmd_graph_auth_check)

    return parser


def main() -> int:
    parser = build_parser()
    args = parser.parse_args()
    return args.func(args)


if __name__ == "__main__":
    sys.exit(main())
