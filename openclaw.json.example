{
  "models": {
    "mode": "merge",
    "providers": {
      "compass": {
        "baseUrl": "https://your-llm-provider.example.com/v1",
        "apiKey": "${COMPASS_API_KEY}",
        "api": "openai-completions",
        "models": [
          {
            "id": "gpt-5.1",
            "name": "GPT 5.1",
            "contextWindow": 200000,
            "maxTokens": 8192
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "compass/gpt-5.1"
      },
      "workspace": "${OPENCLAW_STATE_DIR}/workspace"
    }
  },
  "gateway": {
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_AUTH_TOKEN}"
    }
  },
  "channels": {
    "signal": {
      "enabled": true,
      "account": "${SIGNAL_BOT_NUMBER}",
      "httpUrl": "${SIGNAL_HTTP_URL}",
      "autoStart": true,
      "dmPolicy": "allowlist",
      "allowFrom": ["${SIGNAL_USER_PHONE}"]
    }
  }
}
