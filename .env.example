# ===========================================================================
# OpenClaw Azure Platform — Local Environment Config
# ===========================================================================

# ---------------------------------------------------------------------------
# Azure Shared Environment Variables
# ---------------------------------------------------------------------------
AZURE_ENVIRONMENT=dev
AZURE_LOCATION=eastus
AZURE_REGION_CODE=eus
AZURE_OWNER_SLUG=platform

# ---------------------------------------------------------------------------
# Golden Image
# ---------------------------------------------------------------------------
IMAGE_TAG=latest

# ---------------------------------------------------------------------------
# Per-User Deployment & Local Testing Variables
# ---------------------------------------------------------------------------
USER_SLUG=alice

# API Keys and Secrets (Do not commit real values!)
COMPASS_API_KEY=sk-compass-xxx
GRAPH_MCP_URL=https://your-mcp-gateway.example.com/alice
OPENCLAW_GATEWAY_AUTH_TOKEN=gw-token-xxx

# ---------------------------------------------------------------------------
# Signal Messaging Channel (optional — leave all empty to skip Signal)
# ---------------------------------------------------------------------------
SIGNAL_BOT_NUMBER=+15551234567
SIGNAL_USER_PHONE=+15551234567
SIGNAL_PROXY_AUTH_TOKEN=
