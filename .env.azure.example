# ===========================================================================
# OpenClaw Azure Platform — Per-Environment Configuration (Shared)
# ===========================================================================
# Copy this file to .env.azure.<env> (e.g. .env.azure.dev, .env.azure.prod).
# The Makefile loads .env.azure.$(ENV) automatically.
#
# This file contains SHARED infrastructure config — values that are the
# same for all users in the environment.
#
# Per-user config (SIGNAL_USER_PHONE, API key overrides) goes in
# .env.user.<slug> — see .env.user.example.
#
# Usage:
#   make add-user U=alice ENV=dev    # loads .env.azure.dev + .env.user.alice
#   make add-user U=alice ENV=prod   # loads .env.azure.prod + .env.user.alice
# ===========================================================================

# ---------------------------------------------------------------------------
# Azure Environment (must match the filename suffix)
# ---------------------------------------------------------------------------
AZURE_ENVIRONMENT=dev
AZURE_LOCATION=eastus

# ---------------------------------------------------------------------------
# Shared Resource Name Overrides
# The Makefile derives these from AZURE_ENVIRONMENT by default.  Override
# them here when the prod naming convention differs from the dev convention
# (e.g. resources provisioned externally with a different naming scheme).
#
# Dev defaults (no override needed):
#   AZURE_RESOURCE_GROUP       = rg-openclaw-shared-dev
#   AZURE_CONTAINERAPPS_ENV    = cae-openclaw-shared-dev
#   AZURE_ACR_NAME             = openclawshareddevacr
#   AZURE_KEY_VAULT_NAME       = kvopenclawshareddev
#   NFS_SA_NAME                = nfsopenclawshareddev
#   CAE_NFS_STORAGE_NAME       = openclaw-nfs
#   TF_STATE_RG                = rg-openclaw-tfstate-dev
#   TF_STATE_SA                = tfopenclawstatedev
#
# Prod overrides (uncomment and set for prod):
# AZURE_RESOURCE_GROUP=rg-openclaw-prod
# AZURE_CONTAINERAPPS_ENV=cae-openclaw-prod
# AZURE_ACR_NAME=openclawprodacr
# AZURE_KEY_VAULT_NAME=kvopenclawprod
# NFS_SA_NAME=openclawprodst
# CAE_NFS_STORAGE_NAME=openclaw-nfs-prod
# TF_STATE_RG=rg-openclaw-tfstate-prod
# TF_STATE_SA=tfopenclawstateprod
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Golden Image
# ---------------------------------------------------------------------------
IMAGE_TAG=latest

# ---------------------------------------------------------------------------
# Shared Secrets (defaults for all users — override per-user in .env.user.<slug>)
# ---------------------------------------------------------------------------
COMPASS_BASE_URL=https://api.core42.ai/v1
COMPASS_API_KEY=sk-compass-xxx
OPENCLAW_GATEWAY_AUTH_TOKEN=gw-token-xxx
TAVILY_API_KEY=tvly-xxx

# ---------------------------------------------------------------------------
# Signal Messaging Infrastructure (optional — leave all empty to skip Signal)
# These are SHARED (one bot, one proxy for the entire environment).
# Per-user phone numbers go in .env.user.<slug>.
# ---------------------------------------------------------------------------
# SIGNAL_BOT_NUMBER=+15551234567
# SIGNAL_PROXY_AUTH_TOKEN=
